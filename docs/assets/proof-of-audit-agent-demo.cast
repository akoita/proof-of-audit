[5.585532, "o", "    \u001b[36mFindings:\u001b[0m  \u001b[33m0\u001b[0m\r\n    \u001b[36mReport hash:\u001b[0m  \u001b[33md8e1e99d11…2276\u001b[0m\r\n\r\n    \u001b[1m\u001b[42m\u001b[97m ✓ Draft claim created \u001b[0m\r\n"]
[6.385877, "o", "\r\n\u001b[2m────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[0m\r\n  ⛓️  \u001b[1m\u001b[36mPHASE 4 — Stake & Publish On-Chain\u001b[0m\r\n     \u001b[2m\u001b[3mThe agent puts its money where its mouth is.\u001b[0m\r\n\u001b[2m────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[0m\r\n\r\n\u001b[97m  ▸ Now the agent stakes ETH behind its judgment and publishes the\u001b[0m\r\n\r\n\u001b[97m  ▸ claim on-chain. This makes it visible, portable, and challengeable.\u001b[0m\r\n\r\n"]
[6.626224, "o", "\u001b[90m\u001b[2m  $ curl -s -X POST http://127.0.0.1:8080/audits/9601c1b1-0870-4e4e-828b-983eee890e22/publish -H 'content-type: application/json' -d '{\"stake_wei\": 10000000000000000}'\u001b[0m\r\n"]
[6.871417, "o", "\r\n    \u001b[36mStatus:\u001b[0m  \u001b[33m\u001b[32m\u001b[1mPUBLISHED\u001b[0m\u001b[0m\r\n    \u001b[36mOn-chain audit ID:\u001b[0m  \u001b[33m3\u001b[0m\r\n    \u001b[36mStake:\u001b[0m  \u001b[33m0.0100 ETH\u001b[0m\r\n    \u001b[36mPublish tx:\u001b[0m  \u001b[33m0xe0d3bf78…0cfa\u001b[0m\r\n    \u001b[36mValidation status:\u001b[0m  \u001b[33mrequested\u001b[0m\r\n    \u001b[36mValidation request:\u001b[0m  \u001b[33m0x27735cef…6a54\u001b[0m\r\n\r\n    \u001b[1m\u001b[42m\u001b[97m ✓ Claim published on-chain \u001b[0m\r\n"]
[7.671535, "o", "\r\n\u001b[2m────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[0m\r\n  🔗  \u001b[1m\u001b[36mPHASE 5 — Inspect Validation Trail\u001b[0m\r\n     \u001b[2m\u001b[3mERC-8004-aligned interoperability mirror.\u001b[0m\r\n"]
