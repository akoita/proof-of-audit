[4.228394, "o", "\r\n\u001b[2m────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[0m\r\n  📋  \u001b[1m\u001b[36mPHASE 2 — Select a Benchmark Contract\u001b[0m\r\n     \u001b[2m\u001b[3mPick a known contract to audit.\u001b[0m\r\n"]
