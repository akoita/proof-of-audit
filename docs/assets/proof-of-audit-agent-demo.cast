[0.529851, "o", "\r\n\u001b[2m────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[0m\r\n  🌐  \u001b[1m\u001b[36mLIVE DEPLOYMENT — Base Sepolia\u001b[0m\r\n\u001b[2m────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[0m\r\n\r\n\u001b[97m  ▸ This same flow runs on Base Sepolia with real ETH at stake.\u001b[0m\r\n\r\n    \u001b[36mProofOfAudit:\u001b[0m  \u001b[33m0xf2dA3947d028b85e597Fe1Df4633a87eF4A85F24\u001b[0m\r\n    \u001b[36mBasescan:\u001b[0m  \u001b[33mhttps://sepolia.basescan.org/address/0xf2dA3947d028b85e597Fe1Df4633a87eF4A85F24\u001b[0m\r\n    \u001b[36mIdentityRegistry:\u001b[0m  \u001b[33m0x8004A818BFB912233c491871b3d84c89A494BD9e\u001b[0m\r\n    \u001b[36mValidationRegistry:\u001b[0m  \u001b[33m0x8004B663056A597Dffe9eCcC1965A193B7388713\u001b[0m\r\n\r\n    \u001b[1m\u001b[42m\u001b[97m ✓ Verified on Base Sepolia \u001b[0m\r\n"]
[1.330453, "o", "\r\n\u001b[2m────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[0m\r\n  🔍  \u001b[1m\u001b[36mPHASE 1 — Discover the Auditor\u001b[0m\r\n     \u001b[2m\u001b[3mWho is the agent? Can I trust it?\u001b[0m\r\n\u001b[2m────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[0m\r\n\r\n\u001b[97m  ▸ An agent caller starts by discovering the auditor identity, its\u001b[0m\r\n\r\n\u001b[97m  ▸ ERC-8004 registration, and the active chain configuration.\u001b[0m\r\n\r\n"]
[1.731221, "o", "\u001b[90m\u001b[2m  $ curl -s http://127.0.0.1:8080/auditor\u001b[0m\r\n"]
