[0.129033, "o", "\r\n\r\n\u001b[1m\u001b[36m  ╔═══════════════════════════════════════ 🛡️  Demo ═══════════════════════════════════════╗\u001b[0m\r\n\u001b[36m  ║ \u001b[0m\u001b[1m\u001b[97mPROOF-OF-AUDIT\u001b[0m                                                                        \u001b[36m ║\u001b[0m\r\n\u001b[36m  ║ \u001b[0m\u001b[2mAgent Trust & Enforcement Infrastructure\u001b[0m                                              \u001b[36m ║\u001b[0m\r\n\u001b[36m  ║ \u001b[0m                                                                                      \u001b[36m ║\u001b[0m\r\n\u001b[36m  ║ \u001b[0m\u001b[3m\u001b[97mTrust comes from visible economic commitment,\u001b[0m                                         \u001b[36m ║\u001b[0m\r\n\u001b[36m  ║ \u001b[0m\u001b[3m\u001b[97mnot branding.\u001b[0m                                                                         \u001b[36m ║\u001b[0m\r\n\u001b[1m\u001b[36m  ╚════════════════════════════════════════════════════════════════════════════════════════╝\u001b[0m\r\n"]
