[0.064768, "o", "\r\n=== Discover the auditor service ===\r\n\r\n$ curl -s http://127.0.0.1:18080/auditor\r\n"]
[0.092014, "o", "{\r\n  \"service_id\": \"proof-of-audit-auditor\",\r\n  \"capability\": \"audit_contract\",\r\n  \"agent_id\": 1,\r\n  \"agent_registry\": \"0x2e2ed0cfd3ad2f1d34481277b3204d807ca2f8c2\",\r\n  \"identity_source\": \"project-local-custom\",\r\n  \"validation_registry_address\": \"0xdc11f7e700a4c898ae5caddb1082cffa76512add\",\r\n  \"submission_modes\": [\r\n    \"demo_fixture\",\r\n    \"deployed_address\",\r\n    \"source_bundle\",\r\n    \"repository_url\"\r\n  ],\r\n  \"resolution_modes\": [\r\n    \"deterministic\",\r\n    \"manual_fallback\"\r\n  ]\r\n}\r\n"]
[1.092632, "o", "$ curl -s http://127.0.0.1:18080/auditor/registration\r\n"]
